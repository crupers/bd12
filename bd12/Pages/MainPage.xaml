<Page x:Class="bd12.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:bd12.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Click="go_form">Добавить</Button>
            <Button Click="remove">Удалить</Button>
            <Button Click="go_roles">Роли</Button>
        </StackPanel>

        <ListView Grid.Row="1"
                  ItemsSource="{Binding service.User}" 
                  MouseDoubleClick="Edit" 
                  SelectedItem="{Binding user}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="2" Padding="5">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="id: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding Id}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="Login: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding Login}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="Email: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding Email}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="Роль: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding Role.Title}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="Дата: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>

</Page>

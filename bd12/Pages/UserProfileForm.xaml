<Page x:Class="bd12.Pages.UserProfileForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:bd12.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserProfileForm">
    <Grid>
        <StackPanel Orientation="Vertical">
        <Image Source="{Binding AvatarUrl,UpdateSourceTrigger=PropertyChanged}" Width="200" Height="100"/>
        <StackPanel Margin="10">
            <TextBlock Text="Редактирование профиля" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <StackPanel Margin="0,5">
                <Label>Avatar URL</Label>
                <TextBox Text="{Binding AvatarUrl}"/>
            </StackPanel>

            <StackPanel Margin="0,5">
                <Label>Телефон</Label>
                <TextBox Text="{Binding Phone}"/>
            </StackPanel>

            <StackPanel Margin="0,5">
                <Label>Дата рождения</Label>
                <DatePicker SelectedDate="{Binding Birthday}"/>
            </StackPanel>

            <StackPanel Margin="0,5">
                <Label>О себе</Label>
                <TextBox Text="{Binding Bio}" Height="100" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10" HorizontalAlignment="Center">
                <Button Click="save" Margin="5" Padding="15,8">Сохранить</Button>
                <Button Click="back" Margin="5" Padding="15,8">Назад</Button>
            </StackPanel>
        </StackPanel>
        </StackPanel>
    </Grid>
</Page>
